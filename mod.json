{
    "geode": "5.5.3",
    "gd": {
        "win": "2.2081",
        "android": "2.2081",
        "mac": "2.2081",
        "ios": "2.2081"
    },
    "id": "km7dev.icon_search",
    "name": "Icon Search",
    "version": "v1.0.0-beta.1",
    "developer": "km7dev",
    "description": "Search for icons",
    "dependencies": {
        "geode.node-ids": ">=v1.22.0",
        "hiimjustin000.more_icons": {
            "required": false,
            "version": ">=2.1.1"
        }
    },
    "resources": {
        "spritesheets": {
            "IconSpritesSheet": [
                "res/*.png"
            ]
        }
    },
    "settings": {
        "icon-hack": {
            "type": "bool",
            "name": "Icon Hack",
            "description": "Unlocks all icons <co>in the search menu</c>. This also applies to the regular icon kit.",
            "default": false
        }
    },
    "links": {
        "source": "https://github.com/kingminer7/icon-search"
    },
    "tags": ["utility"]
}
